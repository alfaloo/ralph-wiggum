{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "./dist",
    "strict": true,
    "jsx": "react",
    "types": ["vscode", "node"],
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "webview/**/*.tsx", "webview/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
